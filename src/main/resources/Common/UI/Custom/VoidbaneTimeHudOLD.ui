$Common = "Common.ui";

@MyVoidbaneTex = PatchStyle(TexturePath: "MyBackground.png");
Group {
    LayoutMode: Right;
    Anchor: (Top: 20, Height: 60);

    Group #MyVoidbanePanel {
        Background: @MyVoidbaneTex;
        Anchor: (Right: 20, Top: 20, Width: 100, Height: 50);
        Padding: (Horizontal: 20, Vertical: 10);
        LayoutMode: Left;

        Label #MyVoidbaneLabel {
            Style: (FontSize: 16, Alignment: Center);
            Text: "MyVoidbaneText";
        }

        TextField #MyVoidbaneInput {
            Style: $Common.@DefaultInputFieldStyle;
            Background: @MyVoidbaneTex;
            Anchor: (Top: 30, Width: 200, Height: 50);
            Padding: (Full: 10);
        }
    }
 }